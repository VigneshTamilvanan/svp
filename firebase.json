{
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/api/signQR",
        "run": {
          "serviceId": "signqr",
          "region": "us-central1"
        }
      },
      {
        "source": "/api/public-key",
        "run": {
          "serviceId": "getpublickey",
          "region": "us-central1"
        }
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "functions": {
    "source": "functions"
  }
}
